<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>无界未来 — 探索无界，定义未来</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #fff; color: #000;
    overflow-x: hidden; line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  a { text-decoration: none; color: inherit; transition: color 0.25s; }
  a:hover { color: #0052d9; }
  ul { list-style: none; }
  img { max-width: 100%; display: block; }

  /* 导航栏 */
  .nav {
    position: fixed; top: 0; left: 0; right: 0;
    height: 64px;
    background: #000000;
    backdrop-filter: blur(12px);
    display: flex; align-items: center;
    padding: 0 48px;
    z-index: 9999;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-inner {
    width: 100%; max-width: 1400px;
    margin: 0 auto;
    display: flex; align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 10px;
    flex-shrink: 0;
  }
  .nav-logo-img {
    height: 32px; width: auto;
    object-fit: contain;
  }
  .nav-logo-text {
    font-size: 18px; font-weight: 700;
    color: #fff; letter-spacing: 2px;
    white-space: nowrap;
  }

  .nav-menu { display: flex; align-items: center; gap: 4px; }
  .nav-item {
    position: relative;
    padding: 20px 18px;
    font-size: 14px; font-weight: 500;
    color: rgba(255,255,255,0.85);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav-item:hover { color: #fff; background: rgba(255,255,255,0.06); }
  .nav-item.active { color: #fff; }
  .nav-item-arrow {
    display: inline-block; margin-left: 4px;
    font-size: 10px; transition: transform 0.3s;
    opacity: 0.6;
  }
  .nav-item:hover .nav-item-arrow { transform: rotate(180deg); opacity: 1; }

  .nav-dropdown {
    position: absolute; top: 100%; left: 0;
    min-width: 220px;
    background: #1a1a2e;
    border-radius: 0 0 12px 12px;
    padding: 16px 0;
    opacity: 0; visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.3s ease;
    box-shadow: 0 20px 60px rgba(0,0,0,0.35);
  }
  .nav-item:hover .nav-dropdown {
    opacity: 1; visibility: visible;
    transform: translateY(0);
  }
  .nav-dropdown a {
    display: block; padding: 10px 24px;
    font-size: 13px; color: rgba(255,255,255,0.7);
    transition: all 0.2s;
  }
  .nav-dropdown a:hover {
    color: #fff; background: rgba(255,255,255,0.08);
    padding-left: 28px;
  }

  .nav-right { display: flex; align-items: center; gap: 20px; }
  .nav-lang-switch { display: flex; gap: 4px; }
  .nav-lang-switch span {
    font-size: 12px; color: rgba(255,255,255,0.45); cursor: pointer;
    padding: 4px 8px; border-radius: 4px; transition: all 0.2s;
  }
  .nav-lang-switch span:hover,
  .nav-lang-switch span.active { color: #fff; background: rgba(255,255,255,0.1); }

  .nav-hamburger {
    display: none; flex-direction: column; gap: 5px;
    cursor: pointer; padding: 8px;
  }
  .nav-hamburger span {
    display: block; width: 22px; height: 2px;
    background: #fff; border-radius: 1px; transition: all 0.3s;
  }

  /* HERO — 3.mp4 视频 Logo 核心 */
  .hero {
    position: relative; width: 100%;
    height: 100vh; min-height: 600px;
    overflow: hidden;
    margin-top: 64px;
    background: #000;
    display: flex; align-items: center; justify-content: center;
  }
  .hero-bg-glow {
    position: absolute; inset: 0;
    background: #000;
    pointer-events: none;
  }
  .hero-content {
    position: relative; z-index: 2;
    text-align: center;
    display: flex; flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .hero-logo-img {
    width: clamp(280px, 45vw, 520px);
    height: auto;
    object-fit: contain;
  }
  .hero-tagline {
    font-size: clamp(14px, 2vw, 18px);
    font-weight: 300;
    color: rgba(255,255,255,0.5);
    letter-spacing: 8px;
    text-transform: uppercase;
    margin-top: 8px;
  }
  .hero-desc {
    font-size: clamp(15px, 2vw, 19px);
    font-weight: 300;
    color: rgba(255,255,255,0.7);
    line-height: 1.8;
    max-width: 600px;
    margin-top: 8px;
  }
  .hero-btn-row {
    display: flex; gap: 16px;
    margin-top: 20px;
    flex-wrap: wrap; justify-content: center;
  }
  .hero-btn {
    display: inline-block;
    padding: 14px 36px;
    font-size: 14px; font-weight: 600;
    letter-spacing: 2px; border-radius: 4px;
    transition: all 0.3s;
    cursor: pointer;
  }
  .hero-btn-primary {
    background: #0052d9; color: #fff;
    border: none;
  }
  .hero-btn-primary:hover {
    background: #0041c7;
    transform: translateY(-2px);
    box-shadow: 0 12px 35px rgba(0,82,217,0.35);
    color: #fff;
  }
  .hero-btn-outline {
    background: transparent; color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
  }
  .hero-btn-outline:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.55);
    color: #fff;
  }

  /* 粒子装饰 */
  .hero-particles {
    position: absolute; inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .hero-particle {
    position: absolute;
    width: 2px; height: 2px;
    background: rgba(140,170,250,0.6);
    border-radius: 50%;
    animation: particleFloat linear infinite;
  }
  @keyframes particleFloat {
    0% { opacity: 0; transform: translateY(0) scale(1); }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { opacity: 0; transform: translateY(-200px) scale(0.3); }
  }

  /* 最新动态 */
  .news-section {
    padding: 80px 48px;
    max-width: 1400px; margin: 0 auto;
  }
  .section-header {
    display: flex; justify-content: space-between;
    align-items: baseline; margin-bottom: 48px;
  }
  .section-title {
    font-size: 32px; font-weight: 700;
    color: #000; letter-spacing: -0.5px;
  }
  .section-more {
    font-size: 14px; color: #0052d9;
    font-weight: 500; cursor: pointer;
  }
  .section-more:hover { text-decoration: underline; }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .news-card {
    display: block; border-radius: 8px;
    overflow: hidden;
    background: #f7f8fa;
    transition: all 0.35s ease;
    cursor: pointer;
  }
  .news-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.1);
  }
  .news-card-img {
    width: 100%; aspect-ratio: 16/10;
    object-fit: cover;
    background: linear-gradient(135deg, #e8eaed 0%, #d0d3d9 100%);
    transition: transform 0.5s ease;
  }
  .news-card:hover .news-card-img { transform: scale(1.03); }
  .news-card-body { padding: 24px; }
  .news-card-title {
    font-size: 17px; font-weight: 600;
    color: #000; line-height: 1.5;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .news-card-desc {
    font-size: 13px; color: #666;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3; -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 产品服务 */
  .business-section {
    padding: 80px 48px;
    background: #f5f6f7;
  }
  .business-inner { max-width: 1400px; margin: 0 auto; }
  .business-header {
    text-align: center; margin-bottom: 64px;
  }
  .business-header h2 {
    font-size: 32px; font-weight: 700; margin-bottom: 12px;
  }
  .business-header p {
    font-size: 16px; color: #666; font-weight: 300;
  }

  .business-list { display: flex; flex-direction: column; gap: 72px; }
  .business-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px; align-items: center;
  }
  .business-item:nth-child(even) { direction: rtl; }
  .business-item:nth-child(even) > * { direction: ltr; }

  .business-visual {
    aspect-ratio: 4/3;
    border-radius: 12px;
    overflow: hidden;
    background: linear-gradient(135deg, #e0e4ec 0%, #c8cdd8 100%);
    position: relative;
  }
  .business-visual-inner {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 56px; color: rgba(0,0,0,0.07);
    transition: transform 0.5s ease;
  }
  .business-item:hover .business-visual-inner { transform: scale(1.05); }

  .business-tag {
    display: inline-block;
    font-size: 11px; font-weight: 600;
    letter-spacing: 3px; text-transform: uppercase;
    color: #0052d9;
    margin-bottom: 16px;
    padding: 6px 14px;
    background: rgba(0,82,217,0.07);
    border-radius: 4px;
  }
  .business-info h3 {
    font-size: 26px; font-weight: 700;
    line-height: 1.3; margin-bottom: 16px;
  }
  .business-info p {
    font-size: 15px; color: #555;
    line-height: 1.8; margin-bottom: 24px;
  }
  .business-link {
    font-size: 14px; font-weight: 600;
    color: #0052d9;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .business-link::after {
    content: '\2192'; font-size: 16px;
    transition: transform 0.3s;
  }
  .business-link:hover::after { transform: translateX(4px); }

  /* 公司信息 */
  .company-section {
    padding: 80px 48px;
    max-width: 1400px; margin: 0 auto;
  }
  .company-tabs {
    display: flex; gap: 0;
    margin-bottom: 48px;
    border-bottom: 1px solid #e5e5e5;
  }
  .company-tab {
    padding: 16px 32px;
    font-size: 15px; font-weight: 500;
    color: #666; cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all 0.25s;
  }
  .company-tab:hover { color: #000; }
  .company-tab.active {
    color: #0052d9;
    border-bottom-color: #0052d9;
    font-weight: 600;
  }
  .company-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px; align-items: start;
  }
  .company-main h3 {
    font-size: 26px; font-weight: 700; margin-bottom: 24px;
  }
  .company-main p {
    font-size: 15px; color: #555;
    line-height: 1.9; margin-bottom: 16px;
  }
  .company-side {
    background: #f7f8fa;
    border-radius: 12px;
    padding: 36px;
  }
  .company-stat-row {
    display: flex; justify-content: space-between;
    padding: 18px 0;
    border-bottom: 1px solid #e5e5e5;
  }
  .company-stat-row:last-child { border-bottom: none; }
  .company-stat-label { font-size: 14px; color: #888; }
  .company-stat-value { font-size: 14px; font-weight: 600; color: #000; }

  /* 数据统计 */
  .stats-section {
    padding: 100px 48px;
    background: #fff;
  }
  .stats-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 64px; text-align: center;
  }
  .stat-number {
    font-size: clamp(52px, 9vw, 88px);
    font-weight: 300; letter-spacing: -3px;
    background: linear-gradient(135deg, #1a1a2e 0%, #0052d9 50%, #06b6d4 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .stat-label {
    font-size: 14px; color: rgba(0,0,0,0.45);
    letter-spacing: 3px; margin-top: 16px;
  }

  /* 核心优势 */
  .features-section {
    padding: 80px 48px;
    background: #f5f6f7;
  }
  .features-inner { max-width: 1400px; margin: 0 auto; }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .feature-card {
    background: #fff; border-radius: 12px;
    padding: 36px 24px;
    border: 1px solid #eee;
    transition: all 0.3s;
  }
  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0,82,217,0.1);
  }
  .feature-icon { font-size: 36px; margin-bottom: 16px; }
  .feature-card h3 { font-size: 17px; font-weight: 600; margin-bottom: 10px; }
  .feature-card p { font-size: 13px; color: #666; line-height: 1.7; }

  /* ESG */
  .esg-section {
    padding: 80px 48px;
    background: #000000;
    color: #fff;
  }
  .esg-inner { max-width: 1400px; margin: 0 auto; }
  .esg-header {
    text-align: center; margin-bottom: 56px;
  }
  .esg-header h2 {
    font-size: 32px; font-weight: 700; margin-bottom: 12px;
  }
  .esg-header p {
    font-size: 16px; color: rgba(255,255,255,0.55);
    font-weight: 300;
  }
  .esg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .esg-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 40px 32px;
    transition: all 0.35s;
  }
  .esg-card:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-4px);
  }
  .esg-card-icon { font-size: 36px; margin-bottom: 20px; }
  .esg-card h3 { font-size: 20px; font-weight: 600; margin-bottom: 12px; }
  .esg-card p { font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.7; }

  /* 联系 / 加入我们 */
  .join-section {
    padding: 80px 48px;
    background: #f5f6f7;
  }
  .join-inner { max-width: 1400px; margin: 0 auto; }
  .join-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  .join-card {
    background: #fff;
    border-radius: 12px;
    padding: 44px;
    border: 1px solid #eee;
  }
  .join-card h3 {
    font-size: 22px; font-weight: 700; margin-bottom: 8px;
  }
  .join-card > p {
    font-size: 14px; color: #888; margin-bottom: 28px;
  }
  .join-links { display: flex; flex-direction: column; gap: 12px; }
  .join-link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px;
    background: #f7f8fa;
    border-radius: 8px;
    font-size: 14px; font-weight: 500;
    color: #333;
    transition: all 0.25s;
  }
  .join-link:hover {
    background: #0052d9; color: #fff;
  }
  .join-link-arrow { font-size: 18px; opacity: 0.4; transition: all 0.25s; }
  .join-link:hover .join-link-arrow { opacity: 1; transform: translateX(4px); }

  /* FOOTER */
  .footer {
    background: #000000;
    color: rgba(255,255,255,0.65);
    padding: 64px 48px 32px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .footer-inner { max-width: 1400px; margin: 0 auto; }
  .footer-main {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-logo-area {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 20px;
  }
  .footer-logo-img {
    height: 28px; width: auto;
    object-fit: contain;
  }
  .footer-brand-name {
    font-size: 20px; font-weight: 700;
    color: #fff; letter-spacing: 2px;
  }
  .footer-brand-desc {
    font-size: 13px; line-height: 1.8;
    color: rgba(255,255,255,0.4);
    max-width: 280px;
  }
  .footer-col h4 {
    font-size: 14px; font-weight: 600;
    color: rgba(255,255,255,0.9);
    margin-bottom: 20px;
  }
  .footer-col ul { display: flex; flex-direction: column; gap: 12px; }
  .footer-col a {
    font-size: 13px; color: rgba(255,255,255,0.45);
    transition: color 0.2s;
  }
  .footer-col a:hover { color: #fff; }

  .footer-bottom {
    display: flex; justify-content: space-between;
    align-items: center;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.06);
    flex-wrap: wrap; gap: 16px;
  }
  .footer-copy {
    font-size: 12px; color: rgba(255,255,255,0.3);
  }
  .footer-legal {
    display: flex; gap: 24px; flex-wrap: wrap;
  }
  .footer-legal a {
    font-size: 12px; color: rgba(255,255,255,0.3);
  }
  .footer-legal a:hover { color: rgba(255,255,255,0.6); }

  /* 响应式 */
  @media (max-width: 1024px) {
    .nav-menu { display: none; }
    .nav-hamburger { display: flex; }
    .news-grid { grid-template-columns: repeat(2, 1fr); }
    .business-item { grid-template-columns: 1fr; gap: 40px; }
    .business-item:nth-child(even) { direction: ltr; }
    .company-content { grid-template-columns: 1fr; }
    .esg-grid { grid-template-columns: repeat(2, 1fr); }
    .join-grid { grid-template-columns: 1fr; }
    .footer-main { grid-template-columns: 1fr 1fr; gap: 32px; }
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-inner { grid-template-columns: repeat(3, 1fr); gap: 32px; }
  }
  @media (max-width: 768px) {
    .nav { padding: 0 20px; }
    .hero { margin-top: 56px; min-height: 500px; }
    .news-section, .business-section,
    .company-section, .esg-section, .join-section,
    .stats-section, .features-section {
      padding: 48px 20px;
    }
    .news-grid { grid-template-columns: 1fr; }
    .section-header { flex-direction: column; align-items: flex-start; gap: 12px; }
    .esg-grid { grid-template-columns: 1fr; }
    .footer { padding: 40px 20px 24px; }
    .footer-main { grid-template-columns: 1fr; gap: 28px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
    .company-tabs { overflow-x: auto; }
    .features-grid { grid-template-columns: 1fr; }
    .stats-inner { grid-template-columns: 1fr; gap: 40px; }
    .stats-section { padding: 60px 20px; }
  }

  .fade-in {
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .fade-in.visible {
    opacity: 1; transform: translateY(0);
  }

  /* ===== 星光粒子效果 ===== */
  .hero-stars-container {
    position: absolute; inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 1;
  }
  .star {
    position: absolute;
    border-radius: 50%;
    background: #fff;
    animation: starTwinkle var(--duration) ease-in-out infinite;
    animation-delay: var(--delay);
  }
  @keyframes starTwinkle {
    0%, 100% { opacity: 0.1; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); box-shadow: 0 0 6px 2px rgba(180,210,255,0.8); }
  }
  .star--blue {
    background: #a8d4ff;
    box-shadow: 0 0 4px 1px rgba(140,190,255,0.6);
  }
  .star--purple {
    background: #c4b5fd;
    box-shadow: 0 0 4px 1px rgba(180,150,255,0.6);
  }
  .star--cyan {
    background: #67e8f9;
    box-shadow: 0 0 4px 1px rgba(100,220,255,0.6);
  }
  /* 边缘呼吸光晕（让 logo 区域有微微发光，与背景融为一体） */
  .hero-logo-wrap {
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .hero-logo-wrap::before {
    content: '';
    position: absolute;
    width: 110%; height: 110%;
    background: radial-gradient(ellipse at center, rgba(20,20,40,0.0) 40%, rgba(0,0,0,0.0) 100%);
    border-radius: 50%;
    pointer-events: none;
  }

</style>
</head>
<body>

<!-- 导航栏 -->
<nav class="nav">
  <div class="nav-inner">
    <a href="#" class="nav-logo">
      <video src="3.mp4" autoplay muted loop playsinline class="nav-logo-img" style="height:32px;width:auto;object-fit:contain;"></video>
      <span class="nav-logo-text">无界未来</span>
    </a>

    <div class="nav-menu">
      <div class="nav-item active">
        首页<span class="nav-item-arrow">&#9662;</span>
        <div class="nav-dropdown">
          <a href="#hero">首页总览</a>
          <a href="#news">最新动态</a>
        </div>
      </div>
      <div class="nav-item">
        关于我们<span class="nav-item-arrow">&#9662;</span>
        <div class="nav-dropdown">
          <a href="#company">公司简介</a>
          <a href="#company">企业文化</a>
          <a href="#company">发展历程</a>
          <a href="#company">管理团队</a>
        </div>
      </div>
      <div class="nav-item">
