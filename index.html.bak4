      <div class="company-stat-row"><span class="company-stat-label">服务客户</span><span class="company-stat-value">200+ 家企业</span></div>
      <div class="company-stat-row"><span class="company-stat-label">技术专利</span><span class="company-stat-value">50+ 项专利</span></div>
      <div class="company-stat-row"><span class="company-stat-label">研发占比</span><span class="company-stat-value">年投入 30%+</span></div>
